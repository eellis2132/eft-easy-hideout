<Application x:Class="EasyHideout.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:helpers="clr-namespace:EasyHideout.Helpers"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Themes/Dark.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <helpers:FilePathToImageConverter x:Key="FilePathToImageConverter"/>
            <helpers:BoolToNavStyleConverter x:Key="BoolToNavStyleConverter"/>
            <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
            <helpers:StringToVisibilityConverter x:Key="StringToVisibilityConverter"/>
            <helpers:StringEqualConverter x:Key="StringEqualConverter"/>
            <helpers:InverseBoolConverter x:Key="InverseBoolConverter"/>
            <helpers:BoolToOpacityConverter x:Key="BoolToOpacityConverter"/>
        </ResourceDictionary>
    </Application.Resources>
</Application>
