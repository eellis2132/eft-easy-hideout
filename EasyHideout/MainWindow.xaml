<Window x:Class="EasyHideout.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:EasyHideout.ViewModels"
        xmlns:views="clr-namespace:EasyHideout.Views"
        Title="Easy Hideout" Icon="app.ico" Height="780" Width="1200" MinHeight="600" MinWidth="900"
        WindowStyle="None" ResizeMode="CanResize"
        WindowStartupLocation="Manual"
        Background="{DynamicResource BgSurfaceBrush}"
        Loaded="Window_Loaded"
        Closing="Window_Closing"
        StateChanged="Window_StateChanged">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="44" ResizeBorderThickness="4"
                      GlassFrameThickness="0" UseAeroCaptionButtons="False"/>
    </WindowChrome.WindowChrome>

    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>


    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="44"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="24"/>
        </Grid.RowDefinitions>

        <!-- Top Bar / Custom Title Bar -->
        <Border Grid.Row="0" Background="{DynamicResource BgDeepBrush}"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- App name + DEV badge + update banner -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="16,0,0,0">
                    <TextBlock Text="EASY HIDEOUT" FontSize="13" FontWeight="Bold"
                               Foreground="{DynamicResource AccentBrush}"/>
                    <Border x:Name="DevBadge" Background="#FF8B0000" CornerRadius="3"
                            Padding="5,1" Margin="8,0,0,0" Visibility="Collapsed">
                        <TextBlock Text="DEV" FontSize="10" FontWeight="Bold"
                                   Foreground="#FFFF6B6B"/>
                    </Border>
                    <Button Background="Transparent" BorderThickness="0" Padding="6,1" Margin="8,0,0,0"
                            Cursor="Hand" WindowChrome.IsHitTestVisibleInChrome="True"
                            Click="UpdateBadge_Click"
                            Visibility="{Binding UpdateAvailable, Converter={StaticResource BoolToVisibilityConverter}}">
                        <Border Background="#0D2B0D" CornerRadius="3" Padding="5,1">
                            <TextBlock Text="↓ Update available" FontSize="10" FontWeight="Bold" Foreground="#4CAF50"/>
                        </Border>
                    </Button>
                </StackPanel>

                <!-- Profile selector (center-right) -->
                <Button Grid.Column="2" Background="Transparent" BorderThickness="0"
                        Padding="12,0" Cursor="Hand" VerticalAlignment="Stretch"
                        WindowChrome.IsHitTestVisibleInChrome="True"
                        Command="{Binding NavProfileManagementCommand}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Profile: " Foreground="{DynamicResource TextMutedBrush}" VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding ActiveProfileName}" Foreground="{DynamicResource AccentBrush}"
                                   VerticalAlignment="Center" FontWeight="SemiBold"/>
                    </StackPanel>
                </Button>

                <!-- Window controls -->
                <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Stretch"
                            WindowChrome.IsHitTestVisibleInChrome="True">
                    <Button x:Name="MinimizeBtn" Width="44" Background="Transparent" BorderThickness="0"
                            FontSize="14" VerticalAlignment="Stretch" Cursor="Hand"
                            Click="MinimizeBtn_Click" ToolTip="Minimize">
                        <TextBlock Text="&#x2013;" Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                    </Button>
                    <Button x:Name="MaximizeBtn" Width="44" Background="Transparent" BorderThickness="0"
                            FontSize="12" VerticalAlignment="Stretch" Cursor="Hand"
                            Click="MaximizeBtn_Click" ToolTip="Maximize">
                        <TextBlock x:Name="MaximizeBtnText" Text="&#x25A1;"
                                   Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                    </Button>
                    <Button x:Name="CloseBtn" Width="44" Background="Transparent" BorderThickness="0"
                            FontSize="12" VerticalAlignment="Stretch" Cursor="Hand"
                            Click="CloseBtn_Click" ToolTip="Close">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                                <Setter Property="Background" Value="Transparent"/>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#C0232323"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <TextBlock Text="&#x2715;" Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Main area -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="180"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Sidebar -->
            <Border Grid.Column="0" Background="{DynamicResource SidebarBrush}"
                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,1,0">
                <StackPanel>
                    <Button Margin="0,8,0,0"
                            Style="{Binding IsPriorityActive, Converter={StaticResource BoolToNavStyleConverter}}"
                            Command="{Binding NavPriorityCommand}">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="★" Width="18" FontSize="11" TextAlignment="Center" VerticalAlignment="Center"
                                       Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                            <TextBlock Text="Priority" FontSize="13" VerticalAlignment="Center"
                                       Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                        </StackPanel>
                    </Button>
                    <Button Style="{Binding IsFocusNodeActive, Converter={StaticResource BoolToNavStyleConverter}}"
                            Command="{Binding NavFocusNodeCommand}">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="◎" Width="18" FontSize="11" TextAlignment="Center" VerticalAlignment="Center"
                                       Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                            <TextBlock Text="Focus Station" FontSize="13" VerticalAlignment="Center"
                                       Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                        </StackPanel>
                    </Button>
                    <Button Style="{Binding IsActiveNodesActive, Converter={StaticResource BoolToNavStyleConverter}}"
                            Command="{Binding NavActiveNodesCommand}">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="≡" Width="18" FontSize="14" TextAlignment="Center" VerticalAlignment="Center"
                                       Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                            <TextBlock Text="Stations" FontSize="13" VerticalAlignment="Center"
                                       Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                        </StackPanel>
                    </Button>
                    <Button Style="{Binding IsTotalItemPoolActive, Converter={StaticResource BoolToNavStyleConverter}}"
                            Command="{Binding NavTotalItemPoolCommand}">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="☰" Width="18" FontSize="11" TextAlignment="Center" VerticalAlignment="Center"
                                       Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                            <TextBlock Text="Item Pool" FontSize="13" VerticalAlignment="Center"
                                       Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                        </StackPanel>
                    </Button>
                    <Button Style="{Binding IsShoppingActive, Converter={StaticResource BoolToNavStyleConverter}}"
                            Command="{Binding NavShoppingCommand}">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="✓" Width="18" FontSize="12" TextAlignment="Center" VerticalAlignment="Center"
                                       Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                            <TextBlock Text="Shopping" FontSize="13" VerticalAlignment="Center"
                                       Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                        </StackPanel>
                    </Button>
                    <Button Style="{Binding IsWishlistActive, Converter={StaticResource BoolToNavStyleConverter}}"
                            Command="{Binding NavWishlistCommand}">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="♥" Width="18" FontSize="11" TextAlignment="Center" VerticalAlignment="Center"
                                       Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                            <TextBlock Text="Wishlist" FontSize="13" VerticalAlignment="Center"
                                       Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                        </StackPanel>
                    </Button>
                    <Separator Margin="12,12"/>
                    <Button Style="{Binding IsSettingsActive, Converter={StaticResource BoolToNavStyleConverter}}"
                            Command="{Binding NavSettingsCommand}">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="⚙" Width="18" FontSize="11" TextAlignment="Center" VerticalAlignment="Center"
                                       Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                            <TextBlock Text="Settings" FontSize="13" VerticalAlignment="Center"
                                       Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Border>

            <!-- Content -->
            <Grid Grid.Column="1">
                <views:PriorityView
                    Visibility="{Binding DataContext.IsPriorityActive, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource BoolToVisibilityConverter}}"/>
                <views:FocusNodeView
                    Visibility="{Binding DataContext.IsFocusNodeActive, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource BoolToVisibilityConverter}}"/>
                <views:ActiveNodesView
                    Visibility="{Binding DataContext.IsActiveNodesActive, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource BoolToVisibilityConverter}}"/>
                <views:TotalItemPoolView
                    Visibility="{Binding DataContext.IsTotalItemPoolActive, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource BoolToVisibilityConverter}}"/>
                <views:ShoppingView
                    Visibility="{Binding DataContext.IsShoppingActive, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource BoolToVisibilityConverter}}"/>
                <views:WishlistView
                    Visibility="{Binding DataContext.IsWishlistActive, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource BoolToVisibilityConverter}}"/>
                <views:IgnoredItemsView
                    Visibility="{Binding DataContext.IsIgnoredItemsActive, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource BoolToVisibilityConverter}}"/>
                <views:SettingsView x:Name="SettingsViewControl"
                    Visibility="{Binding DataContext.IsSettingsActive, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource BoolToVisibilityConverter}}"/>
            </Grid>
        </Grid>

        <!-- Tooltip bar -->
        <Border Grid.Row="2" Background="{DynamicResource BgDeepBrush}"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0">
            <Grid Margin="16,0">
                <TextBlock Text="{Binding Tooltip.CurrentMessage}" Foreground="{DynamicResource TextMutedBrush}"
                           VerticalAlignment="Center" FontSize="11" HorizontalAlignment="Left"/>
                <TextBlock Text="{Binding VersionDisplay}" Foreground="{DynamicResource TextMutedBrush}"
                           VerticalAlignment="Center" FontSize="11" HorizontalAlignment="Right"/>
            </Grid>
        </Border>
    </Grid>
</Window>
