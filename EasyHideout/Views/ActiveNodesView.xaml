<UserControl x:Class="EasyHideout.Views.ActiveNodesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:EasyHideout.ViewModels">

    <UserControl.DataContext>
        <vm:ActiveNodesViewModel/>
    </UserControl.DataContext>

    <!-- 3×3 grid: Row0|Row1|Row2 / Col0|Col1|Col2
         Code-behind sets GridLength values based on dock position.
         Detail panel, splitter, and station content bind their Grid.Row/Col from the VM. -->
    <Grid x:Name="LayoutGrid">
        <Grid.RowDefinitions>
            <RowDefinition x:Name="GridRow0" Height="*"/>
            <RowDefinition x:Name="GridRow1" Height="0"/>
            <RowDefinition x:Name="GridRow2" Height="0"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition x:Name="GridCol0" Width="300"/>
            <ColumnDefinition x:Name="GridCol1" Width="5"/>
            <ColumnDefinition x:Name="GridCol2" Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ══════════════════════════════════════════ DETAIL PANEL ══ -->
        <Border Grid.Row="{Binding DetailRow}"
                Grid.Column="{Binding DetailColumn}"
                Grid.RowSpan="{Binding DetailRowSpan}"
                Grid.ColumnSpan="{Binding DetailColSpan}"
                Background="{DynamicResource BgDeepBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0">

            <Grid>
                <!-- No-selection placeholder -->
                <TextBlock Text="Select a station to view details"
                           HorizontalAlignment="Center" VerticalAlignment="Center"
                           Foreground="{DynamicResource TextMutedBrush}" FontSize="12">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding HasSelection}" Value="False">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>

                <!-- Detail content (visible when a station is selected) -->
                <Grid>
                    <Grid.Style>
                        <Style TargetType="Grid">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding HasSelection}" Value="True">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Grid.Style>

                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Station header -->
                    <Border Grid.Row="0" Padding="12,10"
                            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1">
                        <StackPanel>
                            <TextBlock Text="{Binding SelectedName}"
                                       FontSize="14" FontWeight="SemiBold"
                                       Foreground="{DynamicResource AccentBrush}"/>
                            <TextBlock Text="{Binding SelectedLevelText}"
                                       FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}"
                                       Margin="0,2,0,0"/>
                        </StackPanel>
                    </Border>

                    <!-- ── VERTICAL body (left / right dock) ── -->
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="12,8">
                        <ScrollViewer.Style>
                            <Style TargetType="ScrollViewer">
                                <Setter Property="Visibility" Value="Visible"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsHorizontalDock}" Value="True">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ScrollViewer.Style>
                        <StackPanel>
                            <!-- Blocked warning -->
                            <Border Padding="8" Margin="0,0,0,8" Background="#1F1208" CornerRadius="3">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SelectedStation.IsBlocked}" Value="True">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <StackPanel>
                                    <TextBlock Text="🔒 Requires:" FontSize="11" FontWeight="SemiBold"
                                               Foreground="#FF9500" Margin="0,0,0,4"/>
                                    <ItemsControl ItemsSource="{Binding BlockingDeps}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <StackPanel>
                                                    <Button Content="{Binding DisplayText}"
                                                            Command="{Binding DataContext.NavigateToDependencyCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                            CommandParameter="{Binding}"
                                                            Background="Transparent" BorderThickness="0"
                                                            Padding="0,2" HorizontalAlignment="Left" Cursor="Hand" FontSize="11">
                                                        <Button.Style>
                                                            <Style TargetType="Button">
                                                                <Setter Property="Visibility" Value="Visible"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsNavigable}" Value="False">
                                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Button.Style>
                                                        <Button.Template>
                                                            <ControlTemplate TargetType="Button">
                                                                <TextBlock x:Name="link" Text="{TemplateBinding Content}"
                                                                           Foreground="#FF9500" TextDecorations="Underline"/>
                                                                <ControlTemplate.Triggers>
                                                                    <Trigger Property="IsMouseOver" Value="True">
                                                                        <Setter TargetName="link" Property="Foreground" Value="#FFFFFF"/>
                                                                    </Trigger>
                                                                </ControlTemplate.Triggers>
                                                            </ControlTemplate>
                                                        </Button.Template>
                                                    </Button>
                                                    <TextBlock Text="{Binding DisplayText}" FontSize="11"
                                                               Foreground="#FF9500" Padding="0,2">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsNavigable}" Value="False">
                                                                        <Setter Property="Visibility" Value="Visible"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                </StackPanel>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>

                            <!-- L+1 Items -->
                            <StackPanel>
                                <StackPanel.Style>
                                    <Style TargetType="StackPanel">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SelectedStation.IsMaxed}" Value="False">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </StackPanel.Style>
                                <TextBlock Text="NEXT LEVEL ITEMS" FontSize="10" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextMutedBrush}" Margin="0,0,0,6"/>
                                <TextBlock Text="No item requirements" FontSize="11"
                                           Foreground="{DynamicResource TextMutedBrush}" Margin="0,0,0,4">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding L1Items.Count}" Value="0">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                                <ItemsControl ItemsSource="{Binding L1Items}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Margin="0,1,0,0" Padding="6,5" CornerRadius="3">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Background" Value="{DynamicResource BgCardBrush}"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsFullyStocked}" Value="True">
                                                                <Setter Property="Background" Value="#0D2B0D"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="24"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <Image Grid.Column="0" Width="20" Height="20"
                                                           Source="{Binding IconPath, Converter={StaticResource FilePathToImageConverter}}"
                                                           RenderOptions.BitmapScalingMode="HighQuality"/>
                                                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="4,0">
                                                        <Border Background="#99331A" CornerRadius="2" Padding="3,1" Margin="0,0,4,0"
                                                                Visibility="{Binding FoundInRaid, Converter={StaticResource BoolToVisibilityConverter}}">
                                                            <TextBlock Text="FiR" FontSize="8" FontWeight="Bold" Foreground="#FFAA88"/>
                                                        </Border>
                                                        <TextBlock Text="{Binding DisplayName}" FontSize="11"
                                                                   VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                                    </StackPanel>
                                                    <TextBlock Grid.Column="2" Text="{Binding QuantityText}" FontSize="11" VerticalAlignment="Center">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsFullyStocked}" Value="True">
                                                                        <Setter Property="Foreground" Value="#4CAF50"/>
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding IsCurrency}" Value="True">
                                                                        <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>

                            <!-- L+2 Items -->
                            <StackPanel Margin="0,12,0,0">
                                <StackPanel.Style>
                                    <Style TargetType="StackPanel">
                                        <Setter Property="Visibility" Value="Visible"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding L2Items.Count}" Value="0">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </StackPanel.Style>
                                <TextBlock Text="L+2 ITEMS" FontSize="10" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextMutedBrush}" Margin="0,0,0,6"/>
                                <ItemsControl ItemsSource="{Binding L2Items}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Margin="0,1,0,0" Padding="6,5" CornerRadius="3"
                                                    BorderThickness="2,0,0,0" BorderBrush="#2A4A6A">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Background" Value="{DynamicResource BgElevatedBrush}"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsFullyStocked}" Value="True">
                                                                <Setter Property="Background" Value="#0D2B0D"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="24"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <Image Grid.Column="0" Width="20" Height="20"
                                                           Source="{Binding IconPath, Converter={StaticResource FilePathToImageConverter}}"
                                                           RenderOptions.BitmapScalingMode="HighQuality"/>
                                                    <TextBlock Grid.Column="1" Text="{Binding DisplayName}" FontSize="11"
                                                               VerticalAlignment="Center" Margin="4,0" TextTrimming="CharacterEllipsis"/>
                                                    <TextBlock Grid.Column="2" Text="{Binding QuantityText}" FontSize="11"
                                                               VerticalAlignment="Center" Foreground="{DynamicResource TextMutedBrush}"/>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>

                            <!-- Max level message -->
                            <TextBlock Text="This station is fully upgraded." FontSize="12" Foreground="#4CAF50"
                                       HorizontalAlignment="Center" Margin="0,20">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SelectedStation.IsMaxed}" Value="True">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>
                    </ScrollViewer>

                    <!-- ── HORIZONTAL body (top / bottom dock) ── -->
                    <Grid Grid.Row="1" Margin="0,4">
                        <Grid.Style>
                            <Style TargetType="Grid">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsHorizontalDock}" Value="True">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Grid.Style>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="1"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- Blocked warning (spans all cols when visible) -->
                        <Border Grid.Column="0" Grid.ColumnSpan="4"
                                Padding="8" Margin="8,4,8,0" Background="#1F1208" CornerRadius="3"
                                VerticalAlignment="Top">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SelectedStation.IsBlocked}" Value="True">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,0">
                                <TextBlock Text="🔒 Requires: " FontSize="11" FontWeight="SemiBold"
                                           Foreground="#FF9500"/>
                                <ItemsControl ItemsSource="{Binding BlockingDeps}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate><StackPanel Orientation="Horizontal"/></ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal">
                                                <Button Content="{Binding DisplayText}"
                                                        Command="{Binding DataContext.NavigateToDependencyCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        CommandParameter="{Binding}"
                                                        Background="Transparent" BorderThickness="0"
                                                        Padding="0,0,8,0" HorizontalAlignment="Left" Cursor="Hand" FontSize="11">
                                                    <Button.Style>
                                                        <Style TargetType="Button">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsNavigable}" Value="False">
                                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Button.Style>
                                                    <Button.Template>
                                                        <ControlTemplate TargetType="Button">
                                                            <TextBlock x:Name="link" Text="{TemplateBinding Content}"
                                                                       Foreground="#FF9500" TextDecorations="Underline"/>
                                                            <ControlTemplate.Triggers>
                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                    <Setter TargetName="link" Property="Foreground" Value="#FFFFFF"/>
                                                                </Trigger>
                                                            </ControlTemplate.Triggers>
                                                        </ControlTemplate>
                                                    </Button.Template>
                                                </Button>
                                                <TextBlock Text="{Binding DisplayText}" FontSize="11"
                                                           Foreground="#FF9500" Padding="0,0,8,0">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsNavigable}" Value="False">
                                                                    <Setter Property="Visibility" Value="Visible"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </StackPanel>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>

                        <!-- L+1 column -->
                        <Grid Grid.Column="0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Text="NEXT LEVEL ITEMS" FontSize="10" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextMutedBrush}" Margin="8,4,8,4"/>
                            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="8,0">
                                <ItemsControl ItemsSource="{Binding L1Items}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Margin="0,1,0,0" Padding="5,4" CornerRadius="3">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Background" Value="{DynamicResource BgCardBrush}"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsFullyStocked}" Value="True">
                                                                <Setter Property="Background" Value="#0D2B0D"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="20"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <Image Grid.Column="0" Width="16" Height="16"
                                                           Source="{Binding IconPath, Converter={StaticResource FilePathToImageConverter}}"
                                                           RenderOptions.BitmapScalingMode="HighQuality"/>
                                                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="4,0">
                                                        <Border Background="#99331A" CornerRadius="2" Padding="3,1" Margin="0,0,4,0"
                                                                Visibility="{Binding FoundInRaid, Converter={StaticResource BoolToVisibilityConverter}}">
                                                            <TextBlock Text="FiR" FontSize="8" FontWeight="Bold" Foreground="#FFAA88"/>
                                                        </Border>
                                                        <TextBlock Text="{Binding DisplayName}" FontSize="10"
                                                                   VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                                    </StackPanel>
                                                    <TextBlock Grid.Column="2" Text="{Binding QuantityText}" FontSize="10" VerticalAlignment="Center">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsFullyStocked}" Value="True">
                                                                        <Setter Property="Foreground" Value="#4CAF50"/>
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding IsCurrency}" Value="True">
                                                                        <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </Grid>

                        <!-- Vertical divider -->
                        <Rectangle Grid.Column="1" Fill="{DynamicResource BorderBrush}" Width="1" VerticalAlignment="Stretch"/>

                        <!-- L+2 column -->
                        <Grid Grid.Column="2">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Text="L+2 ITEMS" FontSize="10" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextMutedBrush}" Margin="8,4,8,4">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Visible"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding L2Items.Count}" Value="0">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="8,0">
                                <ItemsControl ItemsSource="{Binding L2Items}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Margin="0,1,0,0" Padding="5,4" CornerRadius="3"
                                                    BorderThickness="2,0,0,0" BorderBrush="#2A4A6A">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Background" Value="{DynamicResource BgElevatedBrush}"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsFullyStocked}" Value="True">
                                                                <Setter Property="Background" Value="#0D2B0D"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="20"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <Image Grid.Column="0" Width="16" Height="16"
                                                           Source="{Binding IconPath, Converter={StaticResource FilePathToImageConverter}}"
                                                           RenderOptions.BitmapScalingMode="HighQuality"/>
                                                    <TextBlock Grid.Column="1" Text="{Binding DisplayName}" FontSize="10"
                                                               VerticalAlignment="Center" Margin="4,0" TextTrimming="CharacterEllipsis"/>
                                                    <TextBlock Grid.Column="2" Text="{Binding QuantityText}" FontSize="10"
                                                               VerticalAlignment="Center" Foreground="{DynamicResource TextMutedBrush}"/>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </Grid>

                        <!-- Max level message -->
                        <TextBlock Grid.Column="0" Grid.ColumnSpan="3"
                                   Text="This station is fully upgraded." FontSize="12" Foreground="#4CAF50"
                                   HorizontalAlignment="Center" VerticalAlignment="Center">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SelectedStation.IsMaxed}" Value="True">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>

                        <!-- Action buttons (rightmost column in horizontal mode) -->
                        <Border Grid.Column="3" Padding="8,6" MinWidth="180"
                                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1,0,0,0">
                            <StackPanel VerticalAlignment="Center">
                                <Border Padding="6" Margin="0,0,0,6"
                                        Background="{DynamicResource BgElevatedBrush}" CornerRadius="3">
                                    <StackPanel>
                                        <TextBlock Text="FORCE LEVEL" FontSize="9" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource TextMutedBrush}" Margin="0,0,0,4"/>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="4"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <ComboBox Grid.Column="0" ItemsSource="{Binding ForceTargetLevels}"
                                                      SelectedItem="{Binding SelectedForceLevel}"
                                                      FontSize="11" Padding="6,3">
                                                <ComboBox.ItemTemplate>
                                                    <DataTemplate>
                                                        <TextBlock Text="{Binding StringFormat='Level {0}'}"/>
                                                    </DataTemplate>
                                                </ComboBox.ItemTemplate>
                                            </ComboBox>
                                            <Button Grid.Column="2" Content="Apply"
                                                    Command="{Binding ForceCommand}"
                                                    IsEnabled="{Binding CanForce}"
                                                    Style="{StaticResource AccentButton}"
                                                    Padding="10,4" FontSize="11"/>
                                        </Grid>
                                    </StackPanel>
                                </Border>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="6"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Button Grid.Column="0" Content="↑ Upgrade"
                                            Style="{StaticResource AccentButton}"
                                            Command="{Binding MarkUpgradedCommand}"
                                            IsEnabled="{Binding CanMarkUpgraded}"
                                            FontSize="11"/>
                                    <Button Grid.Column="2" Content="↓ Down"
                                            Command="{Binding DowngradeCommand}"
                                            IsEnabled="{Binding CanDowngrade}"
                                            FontSize="11"/>
                                </Grid>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <!-- Action buttons (vertical mode only) -->
                    <Border Grid.Row="2" Padding="12,10"
                            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Visibility" Value="Visible"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsHorizontalDock}" Value="True">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <StackPanel>
                            <Border Padding="8" Margin="0,0,0,8"
                                    Background="{DynamicResource BgElevatedBrush}" CornerRadius="3">
                                <StackPanel>
                                    <TextBlock Text="FORCE LEVEL  —  no items consumed"
                                               FontSize="10" FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextMutedBrush}" Margin="0,0,0,6"/>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="6"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <ComboBox Grid.Column="0" ItemsSource="{Binding ForceTargetLevels}"
                                                  SelectedItem="{Binding SelectedForceLevel}"
                                                  FontSize="11" Padding="6,3">
                                            <ComboBox.ItemTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding StringFormat='Level {0}'}"/>
                                                </DataTemplate>
                                            </ComboBox.ItemTemplate>
                                        </ComboBox>
                                        <Button Grid.Column="2" Content="Apply"
                                                Command="{Binding ForceCommand}"
                                                IsEnabled="{Binding CanForce}"
                                                Style="{StaticResource AccentButton}"
                                                Padding="14,4" FontSize="11"/>
                                    </Grid>
                                </StackPanel>
                            </Border>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Button Grid.Column="0" Content="↑ Mark Upgraded"
                                        Style="{StaticResource AccentButton}"
                                        Command="{Binding MarkUpgradedCommand}"
                                        IsEnabled="{Binding CanMarkUpgraded}"/>
                                <Button Grid.Column="2" Content="↓ Downgrade"
                                        Command="{Binding DowngradeCommand}"
                                        IsEnabled="{Binding CanDowngrade}"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                </Grid>
            </Grid>
        </Border>

        <!-- ══════════════════════════════════════════ SPLITTER ══ -->
        <GridSplitter x:Name="DetailSplitter"
                      Grid.Row="{Binding SplitterRow}"
                      Grid.Column="{Binding SplitterColumn}"
                      Grid.RowSpan="{Binding SplitterRowSpan}"
                      Grid.ColumnSpan="{Binding SplitterColSpan}"
                      ResizeDirection="{Binding SplitterResizeDirection}"
                      Background="{DynamicResource BorderBrush}"
                      HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                      ShowsPreview="True"/>

        <!-- ══════════════════════════════════════════ NODES AREA ══ -->
        <Border Grid.Row="{Binding ContentRow}"
                Grid.Column="{Binding ContentColumn}"
                Grid.RowSpan="{Binding ContentRowSpan}"
                Grid.ColumnSpan="{Binding ContentColSpan}"
                Background="{DynamicResource BgSurfaceBrush}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Padding="12,8"
                        Background="{DynamicResource BgDeepBrush}"
                        BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1">
                    <TextBlock Text="Active Nodes" FontSize="14" FontWeight="SemiBold"
                               Foreground="{DynamicResource AccentBrush}"/>
                </Border>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="8">
                    <ListBox ItemsSource="{Binding Stations}"
                             SelectedItem="{Binding SelectedStation}"
                             Background="Transparent" BorderThickness="0"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListBox.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel/>
                            </ItemsPanelTemplate>
                        </ListBox.ItemsPanel>
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Padding" Value="0"/>
                                <Setter Property="Margin" Value="0"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListBoxItem">
                                            <ContentPresenter/>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Width="148" Height="84" Margin="4" CornerRadius="4" Cursor="Hand">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="{DynamicResource BgCardBrush}"/>
                                            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
                                            <Setter Property="BorderThickness" Value="1"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsNotBuilt}" Value="True">
                                                    <Setter Property="Opacity" Value="0.6"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding IsBlocked}" Value="True">
                                                    <Setter Property="Opacity" Value="1"/>
                                                    <Setter Property="BorderBrush" Value="#FF9500"/>
                                                    <Setter Property="BorderThickness" Value="2"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding IsMaxed}" Value="True">
                                                    <Setter Property="BorderBrush" Value="#4CAF50"/>
                                                    <Setter Property="BorderThickness" Value="2"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=IsSelected}" Value="True">
                                                    <Setter Property="Opacity" Value="1"/>
                                                    <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                                                    <Setter Property="BorderThickness" Value="2"/>
                                                    <Setter Property="Background" Value="{DynamicResource BgElevatedBrush}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <Grid Margin="8,6,8,6">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="*"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="5"/>
                                        </Grid.RowDefinitions>
                                        <TextBlock Grid.Row="0" Text="{Binding Name}" FontSize="11"
                                                   FontWeight="SemiBold" TextTrimming="CharacterEllipsis"
                                                   TextWrapping="NoWrap" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Row="1" Text="{Binding LevelDisplay}" FontSize="10">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsBlocked}" Value="True">
                                                            <Setter Property="Foreground" Value="#FF9500"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding IsMaxed}" Value="True">
                                                            <Setter Property="Foreground" Value="#4CAF50"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                        <TextBlock Grid.Row="2" Text="⚠ Next Level Blocked"
                                                   FontSize="9" Foreground="#FF9500" Margin="0,1,0,0">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsBlocked}" Value="True">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                        <ProgressBar Grid.Row="3" Maximum="1.0"
                                                     Value="{Binding CompletionPercent, Mode=OneWay}"
                                                     Height="5" Margin="0"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </ScrollViewer>
            </Grid>
        </Border>

    </Grid>
</UserControl>
