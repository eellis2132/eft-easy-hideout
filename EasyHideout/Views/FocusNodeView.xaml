<UserControl x:Class="EasyHideout.Views.FocusNodeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:EasyHideout.ViewModels">

    <UserControl.DataContext>
        <vm:FocusStationViewModel/>
    </UserControl.DataContext>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ═══ Header ═══ -->
        <Border Grid.Row="0" Padding="16,10"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="Focus Station" FontSize="16" FontWeight="SemiBold"
                           Foreground="{DynamicResource AccentBrush}" VerticalAlignment="Center"/>

                <!-- Station + Level selectors -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Station:" FontSize="12" Foreground="{DynamicResource TextMutedBrush}"
                               VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <ComboBox ItemsSource="{Binding StationOptions}"
                              SelectedItem="{Binding SelectedStation}"
                              Width="200" FontSize="12" Padding="6,4">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Name}"/>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>

                    <TextBlock Text="Target Level:" FontSize="12" Foreground="{DynamicResource TextMutedBrush}"
                               VerticalAlignment="Center" Margin="16,0,8,0"/>
                    <ComboBox ItemsSource="{Binding LevelOptions}"
                              SelectedItem="{Binding SelectedLevel}"
                              Width="80" FontSize="12" Padding="6,4">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding StringFormat='Level {0}'}"/>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ═══ Empty state ═══ -->
        <TextBlock Grid.Row="1"
                   Visibility="{Binding IsEmpty, Converter={StaticResource BoolToVisibilityConverter}}"
                   Text="{Binding EmptyMessage}"
                   HorizontalAlignment="Center" VerticalAlignment="Center"
                   Foreground="{DynamicResource TextMutedBrush}" FontSize="14"/>

        <!-- ═══ Main content (two panels) ═══ -->
        <Grid Grid.Row="1"
              Visibility="{Binding HasSelection, Converter={StaticResource BoolToVisibilityConverter}}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="260"/>
                <ColumnDefinition Width="1"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ══ Build Path ══ -->
            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Background="{DynamicResource BgDeepBrush}"
                        BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1"
                        Padding="12,7">
                    <Grid>
                        <TextBlock Text="BUILD PATH" FontSize="11" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextSecondaryBrush}"/>
                        <TextBlock Text="{Binding PathSummary}" HorizontalAlignment="Right"
                                   FontSize="11" Foreground="{DynamicResource TextMutedBrush}"/>
                    </Grid>
                </Border>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding BuildPath}" Margin="0,4,0,8">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="12,5" Margin="0,1">
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <TextBlock Width="18" FontSize="11" VerticalAlignment="Center"
                                                   Foreground="#4CAF50" Text="✓"
                                                   Visibility="{Binding IsComplete, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                        <TextBlock Width="18" FontSize="11" VerticalAlignment="Center"
                                                   Foreground="{DynamicResource TextMutedBrush}" Text="○"
                                                   Visibility="{Binding IsIncomplete, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                        <TextBlock Text="{Binding Label}" FontSize="12" VerticalAlignment="Center">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsComplete}" Value="True">
                                                            <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}"/>
                                                            <Setter Property="TextDecorations" Value="Strikethrough"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>

            <!-- Column divider -->
            <Border Grid.Column="1" Background="{DynamicResource BorderBrush}"/>

            <!-- ══ Farming List ══ -->
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Background="{DynamicResource BgDeepBrush}"
                        BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1"
                        Padding="12,7">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="60"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="ITEMS TO FARM" FontSize="11" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextSecondaryBrush}"/>
                        <TextBlock Grid.Column="1" Text="FOR UPGRADE" FontSize="11" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextMutedBrush}" HorizontalAlignment="Center"/>
                        <TextBlock Grid.Column="2" Text="NEED" FontSize="11" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextMutedBrush}" HorizontalAlignment="Right"/>
                    </Grid>
                </Border>

                <!-- Items list -->
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <ScrollViewer.Style>
                        <Style TargetType="ScrollViewer">
                            <Setter Property="Visibility" Value="Visible"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding FarmingItems.Count}" Value="0">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </ScrollViewer.Style>
                    <ItemsControl ItemsSource="{Binding FarmingItems}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="0,1,0,0" Padding="12,6"
                                        Background="{DynamicResource BgCardBrush}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="36"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="120"/>
                                            <ColumnDefinition Width="50"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- Icon -->
                                        <Border Grid.Column="0" Width="28" Height="28"
                                                Background="{DynamicResource BgElevatedBrush}"
                                                CornerRadius="3" VerticalAlignment="Center">
                                            <Image Width="26" Height="26"
                                                   Source="{Binding IconPath, Converter={StaticResource FilePathToImageConverter}}"
                                                   RenderOptions.BitmapScalingMode="HighQuality"
                                                   VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                        </Border>

                                        <!-- Name + FiR badge -->
                                        <StackPanel Grid.Column="1" Orientation="Horizontal"
                                                    VerticalAlignment="Center" Margin="6,0,8,0">
                                            <Border Background="#99331A" CornerRadius="2" Padding="3,1" Margin="0,0,5,0"
                                                    Visibility="{Binding FoundInRaid, Converter={StaticResource BoolToVisibilityConverter}}">
                                                <TextBlock Text="FiR" FontSize="9" FontWeight="Bold" Foreground="#FFAA88"/>
                                            </Border>
                                            <TextBlock Text="{Binding DisplayName}" VerticalAlignment="Center"
                                                       TextTrimming="CharacterEllipsis"
                                                       Foreground="{DynamicResource TextPrimaryBrush}"/>
                                        </StackPanel>

                                        <!-- Which upgrade this is for -->
                                        <Border Grid.Column="2" Background="{DynamicResource BgDeepBrush}"
                                                CornerRadius="2" Padding="5,2" Margin="0,0,8,0"
                                                VerticalAlignment="Center" HorizontalAlignment="Center">
                                            <TextBlock Text="{Binding StepLabel}" FontSize="9"
                                                       Foreground="{DynamicResource TextMutedBrush}"/>
                                        </Border>

                                        <!-- Remaining count -->
                                        <TextBlock Grid.Column="3" Text="{Binding Remaining}"
                                                   HorizontalAlignment="Right" VerticalAlignment="Center"
                                                   FontSize="13" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource AccentBrush}"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

                <!-- Empty / done state -->
                <TextBlock Grid.Row="1" Text="{Binding ItemSummary}"
                           HorizontalAlignment="Center" VerticalAlignment="Center"
                           FontSize="13" Foreground="{DynamicResource TextMutedBrush}">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding FarmingItems.Count}" Value="0">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
