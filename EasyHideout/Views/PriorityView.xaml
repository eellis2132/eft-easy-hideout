<UserControl x:Class="EasyHideout.Views.PriorityView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:EasyHideout.ViewModels">

    <UserControl.DataContext>
        <vm:PriorityViewModel/>
    </UserControl.DataContext>

    <UserControl.Resources>

        <!-- L+1 item row template -->
        <DataTemplate x:Key="PriorityRowTemplate">
            <Border Padding="8,5" Margin="0,1" CornerRadius="2"
                    BorderThickness="2,0,0,0"
                    Tag="{Binding DataContext, RelativeSource={RelativeSource AncestorType=UserControl}}"
                    MouseEnter="PriorityRow_MouseEnter"
                    MouseLeave="PriorityRow_MouseLeave">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="BorderBrush" Value="Transparent"/>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{DynamicResource BgCardBrush}"/>
                            </Trigger>
                            <DataTrigger Binding="{Binding IsOneAway}" Value="True">
                                <Setter Property="BorderBrush" Value="#4CAF50"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="30"/>
                        <ColumnDefinition Width="46"/>
                        <ColumnDefinition Width="96"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="60"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0" VerticalAlignment="Center" FontSize="10"
                               Foreground="{DynamicResource TextMutedBrush}">
                        <Run Text="#"/><Run Text="{Binding Rank}"/>
                    </TextBlock>

                    <TextBlock Grid.Column="1" Text="{Binding NodeTag}"
                               VerticalAlignment="Center" FontSize="10" FontWeight="SemiBold"
                               Foreground="{DynamicResource AccentBrush}"/>

                    <Grid Grid.Column="2" VerticalAlignment="Center" Margin="4,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="28"/>
                        </Grid.ColumnDefinitions>
                        <ProgressBar Grid.Column="0" Height="4" VerticalAlignment="Center"
                                     Maximum="1.0"
                                     Value="{Binding CompletionPercent, Mode=OneWay}"/>
                        <TextBlock Grid.Column="1" FontSize="9" HorizontalAlignment="Right"
                                   VerticalAlignment="Center" Margin="2,0,0,0"
                                   Foreground="{DynamicResource TextMutedBrush}"
                                   Text="{Binding CompletionPercent, StringFormat={}{0:0%}}"/>
                    </Grid>

                    <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Center" Margin="6,0,4,0">
                        <Border Background="#99331A" CornerRadius="2" Padding="3,1" Margin="0,0,4,0"
                                Visibility="{Binding FoundInRaid, Converter={StaticResource BoolToVisibilityConverter}}">
                            <TextBlock Text="FiR" FontSize="9" FontWeight="Bold" Foreground="#FFAA88"/>
                        </Border>
                        <TextBlock Text="{Binding DisplayName}" FontSize="11"
                                   VerticalAlignment="Center" TextTrimming="CharacterEllipsis"
                                   Foreground="{DynamicResource TextPrimaryBrush}"/>
                    </StackPanel>

                    <TextBlock Grid.Column="4" VerticalAlignment="Center"
                               HorizontalAlignment="Right" FontSize="11"
                               Foreground="{DynamicResource TextSecondaryBrush}">
                        <Run Text="{Binding QuantityOwned}"/><Run Text=" / "/><Run Text="{Binding QuantityNeeded}"/>
                    </TextBlock>
                </Grid>
            </Border>
        </DataTemplate>

    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="{DynamicResource BgDeepBrush}"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1">
            <TextBlock Text="Priority Lists" FontSize="14" FontWeight="SemiBold"
                       Foreground="{DynamicResource AccentBrush}" Margin="16,8"/>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="1"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ══════════════════════════ FOCUS ITEMS ══════════════════════════ -->
            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Background="{DynamicResource BgDeepBrush}"
                        BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1"
                        Padding="12,7">
                    <StackPanel>
                        <TextBlock Text="FOCUS ITEMS" FontSize="11" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextSecondaryBrush}"/>
                        <TextBlock Text="auto-ranked by cross-station impact" FontSize="9"
                                   Foreground="{DynamicResource TextMutedBrush}" Margin="0,1,0,0"/>
                    </StackPanel>
                </Border>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <ItemsControl ItemsSource="{Binding FocusItems}" Margin="0,4,0,8">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Padding="10,6" Margin="0,1"
                                            ToolTip="{Binding StationsTooltip}"
                                            MouseEnter="FocusRow_MouseEnter"
                                            MouseLeave="PriorityRow_MouseLeave">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="Transparent"/>
                                                <Style.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="{DynamicResource BgCardBrush}"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="32"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="50"/>
                                            </Grid.ColumnDefinitions>

                                            <Border Grid.Column="0" Width="26" Height="26"
                                                    Background="{DynamicResource BgElevatedBrush}"
                                                    CornerRadius="3" VerticalAlignment="Center">
                                                <Image Width="24" Height="24"
                                                       Source="{Binding IconPath, Converter={StaticResource FilePathToImageConverter}}"
                                                       RenderOptions.BitmapScalingMode="HighQuality"
                                                       VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                            </Border>

                                            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="6,0,6,0">
                                                <Border Background="#99331A" CornerRadius="2" Padding="3,1" Margin="0,0,4,0"
                                                        Visibility="{Binding FoundInRaid, Converter={StaticResource BoolToVisibilityConverter}}">
                                                    <TextBlock Text="FiR" FontSize="9" FontWeight="Bold" Foreground="#FFAA88"/>
                                                </Border>
                                                <TextBlock Text="{Binding DisplayName}" FontSize="11"
                                                           VerticalAlignment="Center" TextTrimming="CharacterEllipsis"
                                                           Foreground="{DynamicResource TextPrimaryBrush}"/>
                                            </StackPanel>

                                            <Border Grid.Column="2" Background="#1A2A1A"
                                                    CornerRadius="3" Padding="5,2" Margin="0,0,6,0"
                                                    VerticalAlignment="Center">
                                                <TextBlock Text="{Binding StationLabel}" FontSize="9"
                                                           FontWeight="SemiBold"
                                                           Foreground="#4CAF50"/>
                                            </Border>

                                            <TextBlock Grid.Column="3" FontSize="10"
                                                       HorizontalAlignment="Right" VerticalAlignment="Center"
                                                       Foreground="{DynamicResource TextMutedBrush}">
                                                <Run Text="{Binding TotalRemaining}"/><Run Text=" left"/>
                                            </TextBlock>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <TextBlock HorizontalAlignment="Center" Margin="0,40"
                                   FontSize="12" Foreground="{DynamicResource TextMutedBrush}"
                                   Text="Nothing to focus on — all upgrades complete or blocked.">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding FocusItems.Count}" Value="0">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </StackPanel>
                </ScrollViewer>
            </Grid>

            <!-- Column divider -->
            <Border Grid.Column="1" Background="{DynamicResource BorderBrush}"/>

            <!-- ══════════════════════════ L+1 READINESS ══════════════════════════ -->
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Background="{DynamicResource BgDeepBrush}"
                        BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="L+1 PRIORITY" FontSize="11" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextSecondaryBrush}" Margin="12,7"
                                   VerticalAlignment="Center"/>
                        <StackPanel Grid.Column="1" Orientation="Horizontal"
                                    VerticalAlignment="Center" Margin="0,4,8,4">
                            <TextBlock Text="Show" FontSize="10" Foreground="{DynamicResource TextMutedBrush}"
                                       VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <ComboBox ItemsSource="{Binding LimitOptions}"
                                      SelectedItem="{Binding L1Limit}"
                                      Width="52" FontSize="11" Padding="6,3">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Label}"/>
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                        </StackPanel>
                    </Grid>
                </Border>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <StackPanel>

                        <!-- One-Away section -->
                        <StackPanel>
                            <StackPanel.Style>
                                <Style TargetType="StackPanel">
                                    <Setter Property="Visibility" Value="Visible"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding L1OneAwayItems.Count}" Value="0">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </StackPanel.Style>

                            <Border Background="#0D1F0D" Padding="12,5">
                                <TextBlock Text="⚡  ONE AWAY" FontSize="10" FontWeight="Bold"
                                           Foreground="#4CAF50"/>
                            </Border>
                            <ItemsControl ItemsSource="{Binding L1OneAwayItems}"
                                          ItemTemplate="{StaticResource PriorityRowTemplate}"
                                          Margin="0,0,0,2"/>
                            <Border Height="1" Background="{DynamicResource BorderBrush}" Margin="0,4,0,0"/>
                        </StackPanel>

                        <!-- Regular L+1 list -->
                        <ItemsControl ItemsSource="{Binding L1RegularItems}"
                                      ItemTemplate="{StaticResource PriorityRowTemplate}"
                                      Margin="0,2,0,8"/>

                        <TextBlock HorizontalAlignment="Center" Margin="0,40"
                                   FontSize="12" Foreground="{DynamicResource TextMutedBrush}"
                                   Text="All stations are blocked or maxed.">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding L1RegularItems.Count}" Value="0">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>

                    </StackPanel>
                </ScrollViewer>
            </Grid>

        </Grid>
    </Grid>
</UserControl>
