<UserControl x:Class="EasyHideout.Views.TotalItemPoolView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:EasyHideout.ViewModels">

    <UserControl.DataContext>
        <vm:ItemPoolViewModel/>
    </UserControl.DataContext>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- header: title + search + refresh -->
            <RowDefinition Height="Auto"/>  <!-- overall gathering progress bar -->
            <RowDefinition Height="Auto"/>  <!-- sortable column headers -->
            <RowDefinition Height="*"/>     <!-- item list / empty state -->
        </Grid.RowDefinitions>

        <!-- ═══ Header ═══ -->
        <Border Grid.Row="0" Padding="16,10"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="210"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Item Pool" FontSize="16" FontWeight="SemiBold"
                               Foreground="{DynamicResource AccentBrush}" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding Summary}" FontSize="12"
                               Foreground="{DynamicResource TextMutedBrush}"
                               VerticalAlignment="Center" Margin="12,0,0,0"/>
                </StackPanel>

                <!-- Live search box with placeholder -->
                <Grid Grid.Column="2" VerticalAlignment="Center" Margin="0,0,8,0">
                    <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                             Padding="28,5,8,5"/>
                    <TextBlock Text="🔍  Search items..." IsHitTestVisible="False"
                               Foreground="{DynamicResource TextMutedBrush}"
                               FontSize="12" VerticalAlignment="Center" Margin="8,0,0,0">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SearchText}" Value="">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Grid>

                <Button Grid.Column="3" Content="Refresh" VerticalAlignment="Center"
                        Padding="10,5" Command="{Binding RefreshCommand}"/>
            </Grid>
        </Border>

        <!-- ═══ Overall gathering progress ═══ -->
        <Border Grid.Row="1" Padding="16,7" Background="{DynamicResource BgDeepBrush}"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="72"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="42"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="GATHERED" FontSize="10" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextMutedBrush}" VerticalAlignment="Center"/>
                <ProgressBar Grid.Column="1" Height="6" Maximum="1.0"
                             Value="{Binding GatheringPercent, Mode=OneWay}"
                             VerticalAlignment="Center"/>
                <TextBlock Grid.Column="2" Text="{Binding GatheringLabel}" FontSize="11"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           HorizontalAlignment="Right" VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <!-- ═══ Sortable column headers ═══ -->
        <Border Grid.Row="2" Background="{DynamicResource BgDeepBrush}" Padding="12,5,12,5">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="36"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="72"/>
                    <ColumnDefinition Width="116"/>
                    <ColumnDefinition Width="100"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="1" HorizontalAlignment="Left" VerticalAlignment="Center"
                        Command="{Binding SortByCommand}" CommandParameter="Name"
                        Background="Transparent" BorderThickness="0" Padding="0" Cursor="Hand">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="ITEM" FontSize="11" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextMutedBrush}"/>
                        <TextBlock Text="{Binding SortIndicatorName}" FontSize="10"
                                   Foreground="{DynamicResource AccentBrush}" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <Button Grid.Column="2" HorizontalAlignment="Center" VerticalAlignment="Center"
                        Command="{Binding SortByCommand}" CommandParameter="Needed"
                        Background="Transparent" BorderThickness="0" Padding="0" Cursor="Hand">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="NEED" FontSize="11" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextMutedBrush}"/>
                        <TextBlock Text="{Binding SortIndicatorNeeded}" FontSize="10"
                                   Foreground="{DynamicResource AccentBrush}" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <Button Grid.Column="3" HorizontalAlignment="Center" VerticalAlignment="Center"
                        Command="{Binding SortByCommand}" CommandParameter="Owned"
                        Background="Transparent" BorderThickness="0" Padding="0" Cursor="Hand">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="OWNED" FontSize="11" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextMutedBrush}"/>
                        <TextBlock Text="{Binding SortIndicatorOwned}" FontSize="10"
                                   Foreground="{DynamicResource AccentBrush}" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <Button Grid.Column="4" HorizontalAlignment="Center" VerticalAlignment="Center"
                        Command="{Binding SortByCommand}" CommandParameter="Progress"
                        Background="Transparent" BorderThickness="0" Padding="0" Cursor="Hand">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="PROGRESS" FontSize="11" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextMutedBrush}"/>
                        <TextBlock Text="{Binding SortIndicatorProgress}" FontSize="10"
                                   Foreground="{DynamicResource AccentBrush}" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </Grid>
        </Border>

        <!-- ═══ Item list ═══ -->
        <ScrollViewer Grid.Row="3" VerticalScrollBarVisibility="Auto"
                      Visibility="{Binding HasItems, Converter={StaticResource BoolToVisibilityConverter}}">
            <ItemsControl ItemsSource="{Binding Items}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Margin="0,1,0,0" Padding="12,6,12,6">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Background" Value="{DynamicResource BgCardBrush}"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsFullyStocked}" Value="True">
                                            <Setter Property="Background" Value="#0D2B0D"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="36"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="72"/>
                                    <ColumnDefinition Width="116"/>
                                    <ColumnDefinition Width="100"/>
                                </Grid.ColumnDefinitions>

                                <!-- Icon -->
                                <Border Grid.Column="0" Width="28" Height="28"
                                        Background="{DynamicResource BgElevatedBrush}"
                                        CornerRadius="3" VerticalAlignment="Center">
                                    <Image Width="26" Height="26"
                                           Source="{Binding IconPath, Converter={StaticResource FilePathToImageConverter}}"
                                           RenderOptions.BitmapScalingMode="HighQuality"
                                           VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                </Border>

                                <!-- Item name + FiR badge -->
                                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="6,0,8,0">
                                    <Border Background="#99331A" CornerRadius="2" Padding="3,1" Margin="0,0,5,0"
                                            Visibility="{Binding FoundInRaid, Converter={StaticResource BoolToVisibilityConverter}}">
                                        <TextBlock Text="FiR" FontSize="9" FontWeight="Bold" Foreground="#FFAA88"/>
                                    </Border>
                                    <TextBlock Text="{Binding DisplayName}" VerticalAlignment="Center"
                                               TextTrimming="CharacterEllipsis"/>
                                </StackPanel>

                                <!-- Needed -->
                                <TextBlock Grid.Column="2" Text="{Binding TotalNeeded}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"
                                           Foreground="{DynamicResource TextSecondaryBrush}"/>

                                <!-- Owned: − [input] + -->
                                <Grid Grid.Column="3" VerticalAlignment="Center" HorizontalAlignment="Center" Width="110">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="24"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="24"/>
                                    </Grid.ColumnDefinitions>
                                    <Button Grid.Column="0" Content="−"
                                            Command="{Binding DecrementCommand}"
                                            Padding="0" FontSize="14" FontWeight="SemiBold"
                                            HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                                            Height="24"/>
                                    <TextBox Grid.Column="1"
                                             Text="{Binding QuantityOwned, UpdateSourceTrigger=LostFocus}"
                                             TextAlignment="Center" VerticalAlignment="Center"
                                             Height="24" Padding="2,2"
                                             LostFocus="OwnedTextBox_LostFocus"/>
                                    <Button Grid.Column="2" Content="+"
                                            Command="{Binding IncrementCommand}"
                                            Padding="0" FontSize="13" FontWeight="SemiBold"
                                            HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                                            Height="24"/>
                                </Grid>

                                <!-- Per-row progress bar + label -->
                                <StackPanel Grid.Column="4" VerticalAlignment="Center" Margin="6,0,4,0">
                                    <ProgressBar Height="4" Maximum="1.0"
                                                 Value="{Binding GatheringPercent, Mode=OneWay}"
                                                 Margin="0,0,0,2"/>
                                    <TextBlock FontSize="9" HorizontalAlignment="Center">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}"/>
                                                <Setter Property="Text" Value="{Binding GatheringPercent, StringFormat={}{0:0%}}"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsFullyStocked}" Value="True">
                                                        <Setter Property="Foreground" Value="#4CAF50"/>
                                                        <Setter Property="Text" Value="✓ Full"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- Empty state -->
        <TextBlock Grid.Row="3"
                   Visibility="{Binding IsEmpty, Converter={StaticResource BoolToVisibilityConverter}}"
                   Text="{Binding Summary}"
                   HorizontalAlignment="Center" VerticalAlignment="Center"
                   Foreground="{DynamicResource TextMutedBrush}" FontSize="14"/>
    </Grid>
</UserControl>
